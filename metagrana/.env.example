# Copie para .env e ajuste. Com docker-compose, os valores abaixo já funcionam.

# Conexão com o MongoDB
MONGO_URL=mongodb://localhost:27017
MONGO_DB=metagrana

# (Opcional) Chave da API da Anthropic para dicas financeiras com IA.
# Sem a chave, o sistema gera dicas baseadas em regras — funciona do mesmo jeito.
ANTHROPIC_API_KEY=
